{
  "name": "@cosmosapp/pay_sdk",
  "version": "1.1.0",
  "description": "A powerful, object-oriented JavaScript/TypeScript SDK for the Cosmos Pay Payments API — server SDK (Stellar SEP-7 payment intents, webhooks, products, customers, analytics) plus a browser web client that auto-detects Freighter, xBull, Rabet, LOBSTR & Albedo wallets and signs transactions for you.",
  "keywords": [
    "cosmos",
    "cosmos-pay",
    "stellar",
    "sep-7",
    "payments",
    "payment-intents",
    "webhooks",
    "sdk",
    "api",
    "client",
    "typescript",
    "wallet",
    "freighter",
    "xbull",
    "albedo",
    "rabet",
    "lobstr",
    "browser"
  ],
  "license": "MIT",
  "author": "Cosmos Pay",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CosmosPay/CosmosJS_SDK.git"
  },
  "bugs": {
    "url": "https://github.com/CosmosPay/CosmosJS_SDK/issues"
  },
  "homepage": "https://github.com/CosmosPay/CosmosJS_SDK#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./web": {
      "import": {
        "types": "./dist/web/index.d.ts",
        "default": "./dist/web/index.js"
      },
      "require": {
        "types": "./dist/web/index.d.cts",
        "default": "./dist/web/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run build",
    "test": "node --test test/client.test.mjs test/rest.test.mjs test/payment-intents.test.mjs test/webhooks.test.mjs test/structures.test.mjs test/web.test.mjs test/catalogs.test.mjs",
    "test:watch": "node --test --watch test/client.test.mjs test/rest.test.mjs test/payment-intents.test.mjs test/webhooks.test.mjs test/structures.test.mjs test/web.test.mjs test/catalogs.test.mjs",
    "prepublishOnly": "npm run build",
    "changelog": "node scripts/update-changelog.mjs",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "rimraf": "^6.0.1",
    "semver": "^7.6.3",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "@stellar/stellar-sdk": ">=11"
  },
  "peerDependenciesMeta": {
    "@stellar/stellar-sdk": {
      "optional": true
    }
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
